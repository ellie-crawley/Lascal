{{ 'hid.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #section-id-{{ section.id }}{
    background: {{ section.settings.bg_color }};
  }
  #section-id-{{ section.id }}.card-container {
    padding-top: 10px;
    padding-bottom: 10px;
    margin: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
  }
  #section-id-{{ section.id }}{
    .card-list {
      --row-grid-gutter: 10px;
      --column-grid-gutter: 10px;
      display: flex;
      flex-wrap: wrap;
      row-gap: var(--row-grid-gutter);
      column-gap: var(--column-grid-gutter);
      justify-content: center;
      text-align: center;
    }
    .card-list__link:hover .card-list__card-image {
      opacity: {{ section.settings.image_opacity | times: 1.2 | at_most: 100 }}%;
    }
    .hometitle{
      margin-bottom: 20px;
    }
    .card-list__card-image {
      display: flex;
      width: var(--image-max-width, none);
      max-width: var(--image-max-width, none);
      transition: opacity 100ms;
      opacity: {{ section.settings.image_opacity }}%;
    }
    .card-list__card-image img{
      width: var(--image-max-width, none);
      max-width: var(--image-max-width, none);
    }
    .card-list-wrapper{
      display: flex;
      align-items: flex-start;
      gap: 12px;
      flex: 1;
      border-radius: 13px;
      padding: 14px;
      flex: 1 1 100%;
      max-width: 500px;
      background: {{ section.settings.card_bg_color }};
    }
    .card-list__card-text p{
      font-size: {{section.settings.font_size}}px;
      color: {{section.settings.font_colour}}
    }
    .card-list__card-title{
      font-size: 14px;
      font-weight: bold;
    }
    .card-text{
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      text-align: left;
      gap: 5px;
    }

    {%- for block in section.blocks -%}
      .card-list__card-{{ forloop.index }} {
        --image-max-width: {{ block.settings.image_width }}px;
      }
    {%- endfor -%}

    @media (min-width: 1000px) {
      .card-list {
        --row-grid-gutter: 30px;
        --column-grid-gutter: 30px;
      }
      .card-list__card-text p{
        font-size: calc({{section.settings.font_size}} + 2)px;
      }
    }
  }
{%- endstyle -%}

<div id="section-id-{{ section.id }}" class="card-container hid-container">

  {%- capture cards_html -%}
    {%- for block in section.blocks -%}
      {%- if block.settings.link != blank -%}
        <a class="card-list__link card-list__card card-list__card-{{ forloop.index }}" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
      {%- else -%}
        <div class="card-list-wrapper card-list__card card-list__card-{{ forloop.index }}" {{ block.shopify_attributes }}>
      {%- endif -%}

      {% if block.settings.img_type == 'image' %}
        {%- if block.settings.image != blank -%}
          <div class="card-list__card-image">
            {%- liquid
              assign image_sizes = block.settings.image_width | append: 'px'
              assign image_widths = block.settings.image_width | times: 2 | prepend: ', ' | prepend: block.settings.image_width
              render 'image' with block.settings.image, sizes: image_sizes, widths: image_widths
            -%}
          </div>
        {%- endif -%}
      {% else %}
        {% if block.settings.emoji != blank %}
          <span style="font-size: {{ block.settings.emoji_size }}px">{{ block.settings.emoji }}</span>
        {% endif %}
      {% endif %}
      {%- if block.settings.title != blank or block.settings.subtitle != blank or block.settings.text != blank-%}
        <div class="card-text">
          {%- if block.settings.title != blank -%}
            <h2 class="card-list__card-title">
              {{ block.settings.title | escape }}
            </h2>
          {%- endif -%}
          {%- if block.settings.subtitle != blank -%}
            <p class="card-list__card-subtitle">
              {{ block.settings.subtitle | escape }}
            </p>
          {%- endif -%}

          {%- if block.settings.text != blank -%}
            <div class="card-list__card-text">{{ block.settings.text }}</div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- unless block.settings.link != blank -%}
        </div>
      {%- else -%}
        </a>
      {%- endunless -%}
    {%- endfor -%}
  {%- endcapture -%}

  {% if section.settings.title != blank %}
    <div class="hometitle align-center{% if section.settings.show_title == false %} visually-hidden{% endif %}">
      <h2>
        {{- section.settings.title | escape -}}
      </h2>
    </div>
  {% endif %}
  <div class="card-list card-list--count-{{ section.blocks.size }}">
    {{- cards_html -}}
  </div>
</div>


{% schema %}
{
  "name": "HID card list",
  "class": "section-card-list",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subheading"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show heading",
      "info": "If not visible, heading is still used for accessibility & SEO",
      "default": true
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "center",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ]
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Text size",
      "min": 8,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section color"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "font_colour",
      "label": "Text color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "radio",
          "id": "img_type",
          "label": "Image type",
          "default": "image",
          "options": [
            {
              "value": "image",
              "label": "Image"
            },
            {
              "value": "emoji",
              "label": "Emoji"
            }
          ]
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "visible_if": "{{ block.settings.img_type == 'image' }}"
        },
        {
          "type": "range",
          "id": "image_width",
          "label": "Image width",
          "min": 10,
          "max": 280,
          "step": 10,
          "unit": "px",
          "default": 180,
          "visible_if": "{{ block.settings.img_type == 'image' }}"
        },
        {
          "type": "text",
          "id": "emoji",
          "label": "Emoji",
          "info": "Paste your emoji here",
          "visible_if": "{{ block.settings.img_type == 'emoji' }}"
        },
        {
          "type": "range",
          "id": "emoji_size",
          "label": "Emoji size",
          "min": 6,
          "max": 30,
          "step": 1,
          "unit": "px",
          "default": 14,
          "visible_if": "{{ block.settings.img_type == 'emoji' }}"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HID image with text cards",
      "category": "HID Landing Page",
      "settings": {
      }
    }
  ]
}
{% endschema %}

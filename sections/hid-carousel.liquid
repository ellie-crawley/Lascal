{{ 'hid.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #section-id-{{ section.id }} {
    margin: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
    --cols-per-row-desk: {{ section.settings.per_row_desk }};
    --cols-per-row-mob: {{ section.settings.per_row_mobile }};
  }

  #section-id-{{ section.id }} .hometitle {
    margin-bottom: 20px;
    text-align: center;
  }

  /* ── Grid ── */
  #section-id-{{ section.id }} .product-grid {
    display: grid;
    gap: 24px;
    grid-template-columns: repeat(var(--cols-per-row-desk), 1fr);
  }

  #section-id-{{ section.id }} .product-grid--carousel .slider__item {
    display: none;
  }

  {% assign cols = section.settings.per_row_desk %}
  {% assign item_count = section.blocks.size %}
  {% assign last_slide = item_count | minus: cols | plus: 1 %}
  {% if last_slide < 1 %}{% assign last_slide = 1 %}{% endif %}

  {% for i in (1..last_slide) %}
    {% for j in (0..cols) %}
      {% if j < cols %}
        {% assign item_index = i | plus: j %}
        #slide-{{ section.id }}-{{ i }}:checked ~ * .slider__item--{{ item_index }} { display: block; }
      {% endif %}
    {% endfor %}
  {% endfor %}

  @media (max-width: 767px) {
    #section-id-{{ section.id }} .product-grid {
      grid-template-columns: repeat(var(--cols-per-row-mob), 1fr);
      gap: 16px;
    }
  }

  /* ── Cards ── */
  #section-id-{{ section.id }} .review-card {
    border: 1px solid #ece6df;
    border-radius: 14px;
    padding: 15px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    height: 100%;
    box-sizing: border-box;
  }

  #section-id-{{ section.id }} .review-card__image {
    margin-bottom: 10px;
  }

  #section-id-{{ section.id }} .review-card__image img {
    border-radius: 50%;
    object-fit: cover;
  }

  #section-id-{{ section.id }} .review-card__stars {
    display: flex;
    gap: 2px;
    justify-content: center;
    margin-bottom: 8px;
    color: #f5a623;
    font-size: 18px;
  }

  #section-id-{{ section.id }} .review-card__text {
    flex: 1;
    margin-bottom: 10px;
  }

  #section-id-{{ section.id }} .review-card__author {
    font-weight: 600;
    margin-top: auto;
  }

  /* ── Per-block overrides ── */
  {%- for block in section.blocks -%}
    #section-id-{{ section.id }} .review-block--{{ forloop.index }} .review-card {
      {% if block.settings.logo_bg_color != blank %}
        background: {{ block.settings.logo_bg_color }};
      {% endif %}
      {% if block.settings.font_colour != blank %}
        color: {{ block.settings.font_colour }};
      {% endif %}
      flex-direction: {{ block.settings.text_icon_alignment }};
      {% if block.settings.text_icon_alignment == 'row' %}
        align-items: flex-start;
        text-align: left;
      {% endif %}
    }
    #section-id-{{ section.id }} .review-block--{{ forloop.index }} .review-card__text p {
      font-size: {{ block.settings.font_size }}px;
    }
    #section-id-{{ section.id }} .review-block--{{ forloop.index }} .review-card__image img {
      width: {{ block.settings.image_width }}px;
      max-width: 100%;
    }
  {%- endfor -%}

  /* ── Nav buttons ── */
  #section-id-{{ section.id }} .slider-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 20px;
  }

  #section-id-{{ section.id }} .slider-nav__btn {
    cursor: pointer;
    font-size: 32px;
    line-height: 1;
    padding: 0 12px;
    background: none;
    border: none;
    color: inherit;
    user-select: none;
  }

  #section-id-{{ section.id }} .slider-nav__btn:disabled {
    opacity: 0.2;
    cursor: default;
  }
{%- endstyle -%}

{%- liquid
  assign cols_per_row_desk  = section.settings.per_row_desk
  assign cols_per_row_mob   = section.settings.per_row_mobile
  assign item_count         = section.blocks.size
  assign last_slide         = item_count | minus: cols_per_row_desk | plus: 1
  if last_slide < 1
    assign last_slide = 1
  endif
  assign show_carousel = false
  if item_count > cols_per_row_desk
    assign show_carousel = true
  endif
-%}

<div id="section-id-{{ section.id }}" class="section-id-{{ section.id }} collection-slider-row">

  {%- if show_carousel -%}
    {%- for i in (1..last_slide) -%}
      <input
        type="radio"
        name="slider-{{ section.id }}"
        id="slide-{{ section.id }}-{{ forloop.index }}"
        class="slider-radio"
        style="display:none"
        {% if forloop.first %}checked{% endif %}>
    {%- endfor -%}
  {%- endif -%}

  <div class="container{% if section.settings.full_width %} container--no-max{% endif %}">

    {%- if section.settings.title != blank -%}
      <div class="hometitle{% unless section.settings.show_title %} visually-hidden{% endunless %}">
        <h2>{{ section.settings.title | escape }}</h2>
      </div>
    {%- endif -%}

    <div class="product-grid{% if show_carousel %} product-grid--carousel{% endif %}">
      {%- for block in section.blocks -%}
        {%- liquid
          assign filled_stars = block.settings.star_rating
          assign empty_stars  = 5 | minus: filled_stars
        -%}
        <div
          class="review-block--{{ forloop.index }}{% if show_carousel %} slider__item slider__item--{{ forloop.index }}{% endif %}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.link != blank -%}
            <a class="review-card" href="{{ block.settings.link }}" style="text-decoration:none;">
          {%- else -%}
            <div class="review-card">
          {%- endif -%}

            {%- if block.settings.image != blank -%}
              <div class="review-card__image">
                {%- liquid
                  assign image_w = block.settings.image_width
                  assign image_sizes = image_w | append: 'px'
                  assign image_widths = image_w | times: 2 | prepend: ', ' | prepend: image_w
                  render 'image' with block.settings.image, sizes: image_sizes, widths: image_widths
                -%}
              </div>
            {%- endif -%}

            <div>
              {%- if block.settings.star_rating > 0 -%}
                <div class="review-card__stars" aria-label="{{ block.settings.star_rating }} out of 5 stars">
                  {%- for i in (1..filled_stars) -%}★{%- endfor -%}
                  {%- if empty_stars > 0 -%}
                    {%- for i in (1..empty_stars) -%}☆{%- endfor -%}
                  {%- endif -%}
                </div>
              {%- endif -%}

              {%- if block.settings.text != blank -%}
                <div class="review-card__text">{{ block.settings.text }}</div>
              {%- endif -%}

              {%- if block.settings.author != blank -%}
              <div class="review-card__author">{{ block.settings.author }}</div>
            {%- endif -%}
            </div>

          {%- if block.settings.link != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if show_carousel -%}
      <div class="slider-nav">
        <button
          class="slider-nav__btn slider-nav__btn--prev"
          data-slider="{{ section.id }}"
          aria-label="Previous"
          disabled
        >&#8249;</button>

        <button
          class="slider-nav__btn slider-nav__btn--next"
          data-slider="{{ section.id }}"
          aria-label="Next"
        >&#8250;</button>
      </div>
    {%- endif -%}

  </div>
</div>

{%- if show_carousel -%}
<script>
(function () {
  var sectionId = {{ section.id | json }};
  var lastSlide = {{ last_slide }};
  var current   = 1;

  var root    = document.getElementById('section-id-' + sectionId);
  var prevBtn = root.querySelector('.slider-nav__btn--prev');
  var nextBtn = root.querySelector('.slider-nav__btn--next');

  function goTo(index) {
    if (index < 1 || index > lastSlide) return;
    var radio = document.getElementById('slide-' + sectionId + '-' + index);
    if (radio) radio.checked = true;
    current = index;
    prevBtn.disabled = current === 1;
    nextBtn.disabled = current === lastSlide;
  }

  prevBtn.addEventListener('click', function () { goTo(current - 1); });
  nextBtn.addEventListener('click', function () { goTo(current + 1); });
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "HID Carousel",
  "class": "section-carousel",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show heading",
      "info": "If not visible, heading is still used for accessibility & SEO",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "range",
      "id": "per_row_desk",
      "label": "Items per row (desktop)",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "per_row_mobile",
      "label": "Items per row (mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Reviewer image"
        },
        {
          "type": "range",
          "id": "image_width",
          "label": "Image width",
          "min": 30,
          "max": 200,
          "step": 5,
          "unit": "px",
          "default": 60
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Review text"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name"
        },
        {
          "type": "range",
          "id": "star_rating",
          "label": "Star rating",
          "min": 0,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "radio",
          "id": "text_icon_alignment",
          "label": "Layout",
          "default": "column",
          "options": [
            { "value": "column", "label": "Stacked" },
            { "value": "row",    "label": "Inline"  }
          ]
        },
        {
          "type": "range",
          "id": "font_size",
          "label": "Text size",
          "min": 8,
          "max": 30,
          "step": 1,
          "unit": "px",
          "default": 14
        },
        {
          "type": "color",
          "id": "logo_bg_color",
          "label": "Card background color"
        },
        {
          "type": "color",
          "id": "font_colour",
          "label": "Text color"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HID Carousel",
      "category": "HID Landing Page"
    }
  ]
}
{% endschema %}
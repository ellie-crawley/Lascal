{{ 'hid.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #section-id-{{ section.id }}.logo-container {
    padding-top: 10px;
    padding-bottom: 10px;
    margin: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
  }
  #section-id-{{ section.id }}{
    .carousel-item {
      --gap: 10px;
      display: flex;
      flex-wrap: wrap;
      gap: var(--gap);
      justify-content: center;
      text-align: center;
    }
    .carousel-item__link:hover .carousel-item__logo-image {
      opacity: {{ section.settings.image_opacity | times: 1.2 | at_most: 100 }}%;
    }
    .hometitle{
      margin-bottom: 20px;
    }
    .carousel-item__logo-image {
      display: flex;
      align-items: center;
      width: var(--logo-max-width, none);
      max-width: var(--logo-max-width, none);
      transition: opacity 100ms;
      opacity: {{ section.settings.image_opacity }}%;
    }
    .layout-row .carousel-item__logo-image {
      margin: 0;
    }
    .layout-column .carousel-item__logo-image {
      margin: 0 auto;
    }
    .carousel-item__logo-image img{
      width: var(--logo-max-width, none);
      max-width: var(--logo-max-width, none);
    }
    .carousel-item-wrapper{
      display: flex;
      flex-direction: {{ section.settings.text_icon_alignment }};
      align-items: center;
      gap: 5px;
      flex: 1;
      {% if section.settings.logo_bg_color != blank %}
        border-radius: 9px;
        padding: 11px;
        background: {{section.settings.logo_bg_color}};
      {% endif %}
    }
    .layout--row{
      flex-wrap: nowrap;
    }
    .layout--grid{
      flex-wrap: wrap;
    }
    .layout--grid .carousel-item{
      justify-content: flex-start;
    }
    .layout--grid .carousel-item-wrapper {
      flex: 0 1 calc(50% - (var(--gap) / 2));
    }
    .carousel-item__logo-text p{
      font-size: {{section.settings.font_size}}px;
      color: {{section.settings.font_colour}}
    }

    {%- for block in section.blocks -%}
      .carousel-item__logo-{{ forloop.index }} {
        --logo-max-width: {{ block.settings.image_width }}px;
      }
      .text_icon_alignment-row.carousel-item__logo-{{ forloop.index }} {
        justify-content: {{  block.settings.justify-content }}
      }
    {%- endfor -%}

    @media (min-width: 769px) {
      .layout--grid .carousel-item-wrapper {
        flex: 0 1 calc(33% - (2 * var(--gap)) / 2);
      }
    }

    @media (min-width: 1000px) {
      .carousel-item {
        --gap: 20px;
      }
      .layout--grid .carousel-item-wrapper {
        flex: 0 1 calc(25% - (3 * var(--gap)) / 4);
      }
      .carousel-item__logo-text p{
        font-size: calc({{section.settings.font_size}} + 2)px;
      }
    }
  }
{%- endstyle -%}


{%- liquid
  assign cols_per_row_desk = section.settings.per_row_desk
  assign cols_per_row_mob = section.settings.per_row_mobile
  assign item_count = section.blocks.size
  assign last_slide = item_count | minus: cols_per_row_desk | plus: 1
  assign show_carousel = true
  if item_count <= cols_per_row_desk
    assign show_carousel = false
  endif
  if last_slide < 1
    assign last_slide = 1
  endif
-%}

{% style %}
.hid-product__card{
  border: 1px solid #ece6df;
  border-radius: 14px;
  padding: 15px;
  text-align: center;
}

/* ── Shared grid ── */
.section-id-{{ section.id }} .product-grid {
  display: grid;
  gap: 24px;
  grid-template-columns: repeat({{ item_count }}, 1fr);
}

.section-id-{{ section.id }} .product-grid--carousel {
  grid-template-columns: repeat(var(--cols-per-row-desk), 1fr);
}

@media (max-width: 767px) {
  .section-id-{{ section.id }} .product-grid {
    grid-template-columns: repeat(var(--cols_per_row_mob), 1fr);
    gap: 16px;
  }
}

/* ── Carousel ── */
.section-id-{{ section.id }} .collection-listing--carousel {
  overflow: hidden;
}

.section-id-{{ section.id }} .product-grid--carousel .slider__item {
  display: none;
}

{% assign cols = cols_per_row_desk %}
{% for i in (1..last_slide) %}
  {% for j in (0..cols) %}
    {% if j < cols %}
      {% assign item_index = i | plus: j %}
      #slide-{{ section.id }}-{{ i }}:checked ~ * .slider__item--{{ item_index }} { display: block; }
    {% endif %}
  {% endfor %}
{% endfor %}

/* ── Nav ── */
.section-id-{{ section.id }} .slider-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}

.section-id-{{ section.id }} .slider-nav__btn {
  cursor: pointer;
  font-size: 32px;
  line-height: 1;
  padding: 0 12px;
  background: none;
  border: none;
  color: inherit;
  user-select: none;
}

.section-id-{{ section.id }} .slider-nav__btn:disabled {
  opacity: 0.2;
  cursor: default;
}

.section-id-{{ section.id }} {
  --per-row-desk: {{ cols_per_row_desk }};
  --per-row-mob: {{ cols_per_row_mob }};
  margin: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
}
{% endstyle %}

{%- capture block_html -%}
  {%- for block in section.blocks -%}
    {%- if block.settings.link != blank -%}
      <a class="carousel-item__link carousel-item--{{ forloop.index }} text_image_alignment-{{ section.settings.text_icon_alignment }}" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
    {%- else -%}
      <div class="carousel-item-wrapper carousel-item--{{ forloop.index }} text_image_alignment-{{ section.settings.text_icon_alignment }}" {{ block.shopify_attributes }}>
    {%- endif -%}

    {%- if block.settings.image != blank -%}
      <div class="carousel-item-image">
        {%- liquid
          assign image_sizes = block.settings.image_width | append: 'px'
          assign image_widths = block.settings.image_width | times: 2 | prepend: ', ' | prepend: block.settings.image_width
          render 'image' with block.settings.image, sizes: image_sizes, widths: image_widths
        -%}
      </div>
    {%- endif -%}

    {%- if block.settings.text != blank -%}
      <div class="carousel-item-text">{{ block.settings.text }}</div>
    {%- endif -%}

    {%- unless block.settings.link != blank -%}
      </div>
    {%- else -%}
      </a>
    {%- endunless -%}
  {%- endfor -%}
{%- endcapture -%}

<div class="section-id-{{ section.id }} collection-slider-row">

  {%- if show_carousel -%}
    {% for i in (1..last_slide) %}
      <input
        type="radio"
        name="slider-{{ section.id }}"
        id="slide-{{ section.id }}-{{ forloop.index }}"
        class="slider-radio"
        style="display:none"
        {% if forloop.first %}checked{% endif %}>
    {% endfor %}
  {%- endif -%}

  <div class="container{% if section.settings.full_width %} container--no-max{% endif %}">
    {% if section.settings.title != blank %}
      <div class="hometitle align-center{% if section.settings.show_title == false %} visually-hidden{% endif %}">
        <h2>
          {{- section.settings.title | escape -}}
        </h2>
      </div>
    {% endif %}

    <div class="{% if show_carousel %} block-item--carousel{% endif %}">
      <div class="product-grid product-grid--desk-{{ cols_per_row_desk }} product-grid--mob-{{ cols_per_row_mobile }}{% if show_carousel %} product-grid--carousel{% endif %}">
        {%- for block in section.blocks -%}
          <div class="product-grid__item{% if show_carousel %} slider__item slider__item--{{ forloop.index }}{% endif %}">
            {{- block_html -}}
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div>
      {% if show_carousel %}
        <button
          class="slider-nav__btn slider-nav__btn--prev"
          data-slider="{{ section.id }}"
          data-direction="prev"
          aria-label="Previous"
          disabled
        >&#8249;</button>

        <button
          class="slider-nav__btn slider-nav__btn--next"
          data-slider="{{ section.id }}"
          data-direction="next"
          aria-label="Next"
        >&#8250;</button>
      {% endif %}
    </div>
  </div>
</div>

<script>
(function () {
  var sectionId = {{ section.id | json }};
  var lastSlide = {{ last_slide }};
  var current = 1;

  var prevBtn = document.querySelector('.section-id-' + sectionId + ' .slider-nav__btn--prev');
  var nextBtn = document.querySelector('.section-id-' + sectionId + ' .slider-nav__btn--next');

  function goTo(index) {
    if (index < 1 || index > lastSlide) return;
    var radio = document.getElementById('slide-' + sectionId + '-' + index);
    if (radio) radio.checked = true;
    current = index;
    prevBtn.disabled = current === 1;
    nextBtn.disabled = current === lastSlide;
  }

  prevBtn.addEventListener('click', function () { goTo(current - 1); });
  nextBtn.addEventListener('click', function () { goTo(current + 1); });
})();
</script>

{% schema %}
{
  "name": "HID Carousel",
  "class": "section-carousel",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show heading",
      "info": "If not visible, heading is still used for accessibility & SEO",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "radio",
      "id": "justify-content",
      "label": "Text and Icon alignment",
      "default": "center",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Centre"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "range",
          "id": "image_width",
          "label": "Logo width",
          "min": 10,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 50,
          "info": "Image column width when image and text are inline"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author"
        },
        {
          "type": "range",
          "id": "star_rating",
          "label": "Star Rating",
          "min": 0,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "radio",
          "id": "text_icon_alignment",
          "label": "Text and Icon alignment",
          "default": "column",
          "options": [
            {
              "value": "column",
              "label": "Stacked"
            },
            {
              "value": "row",
              "label": "Inline"
            }
          ]
        },
        {
          "type": "range",
          "id": "font_size",
          "label": "Text size",
          "min": 8,
          "max": 30,
          "step": 1,
          "unit": "px",
          "default": 12
        },
        {
          "type": "color",
          "id": "logo_bg_color",
          "label": "Background color"
        },
        {
          "type": "color",
          "id": "font_colour",
          "label": "Text color"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HID Carousel",
      "category": "HID Landing Page",
      "settings": {
      }
    }
  ]
}
{% endschema %}

{{ 'hid.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #section-id-{{ section.id }} {
    margin: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
  }

  #section-id-{{ section.id }} .hometitle {
    margin-bottom: 20px;
    text-align: center;
  }

  {%- assign cols_desk  = section.settings.per_row_desk -%}
  {%- assign cols_tab   = section.settings.per_row_tab -%}
  {%- assign cols_mob   = section.settings.per_row_mobile -%}
  {%- assign item_count = section.blocks.size -%}

  {%- assign last_slide_desk = item_count | minus: cols_desk | plus: 1 -%}
  {%- if last_slide_desk < 1 -%}{%- assign last_slide_desk = 1 -%}{%- endif -%}

  {%- assign last_slide_tab = item_count | minus: cols_tab | plus: 1 -%}
  {%- if last_slide_tab < 1 -%}{%- assign last_slide_tab = 1 -%}{%- endif -%}

  {%- assign last_slide_mob = item_count | minus: cols_mob | plus: 1 -%}
  {%- if last_slide_mob < 1 -%}{%- assign last_slide_mob = 1 -%}{%- endif -%}

  {%- assign carousel_desk = false -%}
  {%- if item_count > cols_desk -%}{%- assign carousel_desk = true -%}{%- endif -%}

  {%- assign carousel_tab = false -%}
  {%- if item_count > cols_tab -%}{%- assign carousel_tab = true -%}{%- endif -%}

  {%- assign carousel_mob = false -%}
  {%- if item_count > cols_mob -%}{%- assign carousel_mob = true -%}{%- endif -%}

  /* ── Grid ── */
  /* Desktop */
  @media (min-width: 1024px) {
    #section-id-{{ section.id }} .product-grid {
      display: grid;
      gap: 24px;
      {% if carousel_desk %}
        grid-template-columns: repeat({{ cols_desk }}, 1fr);
      {% else %}
        grid-template-columns: repeat({{ item_count }}, 1fr);
      {% endif %}
    }
    {% if carousel_desk %}
      #section-id-{{ section.id }} .product-grid .slider__item {
        display: none;
      }
    {% endif %}
  }

  /* Tablet */
  @media (min-width: 768px) and (max-width: 1023px) {
    #section-id-{{ section.id }} .product-grid {
      display: grid;
      gap: 20px;
      {% if carousel_tab %}
        grid-template-columns: repeat({{ cols_tab }}, 1fr);
      {% else %}
        grid-template-columns: repeat({{ item_count }}, 1fr);
      {% endif %}
    }
    {% if carousel_tab %}
      #section-id-{{ section.id }} .product-grid .slider__item {
        display: none;
      }
    {% endif %}
  }

  /* Mobile */
  @media (max-width: 767px) {
    #section-id-{{ section.id }} .product-grid {
      display: grid;
      gap: 16px;
      {% if carousel_mob %}
        grid-template-columns: repeat({{ cols_mob }}, 1fr);
      {% else %}
        grid-template-columns: repeat({{ item_count }}, 1fr);
      {% endif %}
    }
    {% if carousel_mob %}
      #section-id-{{ section.id }} .product-grid .slider__item {
        display: none;
      }
    {% endif %}
  }

  /* ── Carousel slide visibility rules ── */

  /* Desktop */
  {% if carousel_desk %}
    {% for i in (1..last_slide_desk) %}
      {% for j in (0..cols_desk) %}
        {% if j < cols_desk %}
          {% assign item_index = i | plus: j %}
          {% if item_index <= item_count %}
            @media (min-width: 1024px) {
              #slide-desk-{{ section.id }}-{{ i }}:checked ~ * .slider__item--{{ item_index }} { display: block; }
            }
          {% endif %}
        {% endif %}
      {% endfor %}
    {% endfor %}
  {% endif %}

  /* Tablet */
  {% if carousel_tab %}
    {% for i in (1..last_slide_tab) %}
      {% for j in (0..cols_tab) %}
        {% if j < cols_tab %}
          {% assign item_index = i | plus: j %}
          {% if item_index <= item_count %}
            @media (min-width: 768px) and (max-width: 1023px) {
              #slide-tab-{{ section.id }}-{{ i }}:checked ~ * .slider__item--{{ item_index }} { display: block; }
            }
          {% endif %}
        {% endif %}
      {% endfor %}
    {% endfor %}
  {% endif %}

  /* Mobile */
  {% if carousel_mob %}
    {% for i in (1..last_slide_mob) %}
      {% for j in (0..cols_mob) %}
        {% if j < cols_mob %}
          {% assign item_index = i | plus: j %}
          {% if item_index <= item_count %}
            @media (max-width: 767px) {
              #slide-mob-{{ section.id }}-{{ i }}:checked ~ * .slider__item--{{ item_index }} { display: block; }
            }
          {% endif %}
        {% endif %}
      {% endfor %}
    {% endfor %}
  {% endif %}

  /* ── Cards ── */
  #section-id-{{ section.id }} .review-card {
    border-radius: 14px;
    display: flex;
    flex-direction: column;
    height: 100%;
    box-sizing: border-box;
    justify-content: space-between;
    gap: 10px;
  }

  #section-id-{{ section.id }} .review-card__image img {
    object-fit: cover;
    height: 100%;
    width: 100%;
    border-radius: 14px 0 0 14px;
  }

  #section-id-{{ section.id }} .review-card__text {
    flex: 1;
  }

  #section-id-{{ section.id }} .review-card__author {
    font-weight: 600;
    margin-top: auto;
  }

  #section-id-{{ section.id }} .review-body {
    display: flex;
    flex-direction: column;
    padding: 10px;
    gap: 40px;
    height: 100%;
  }

  #section-id-{{ section.id }} .review-card__stars {
    display: flex;
    gap: 2px;
    justify-content: flex-start;
    font-size: 18px;
  }

  /* ── Per-block overrides ── */
  {%- for block in section.blocks -%}
    #section-id-{{ section.id }} .review-block--{{ forloop.index }} .review-card {
      {% if block.settings.logo_bg_color != blank %}
        background: {{ block.settings.logo_bg_color }};
      {% endif %}
      {% if block.settings.font_colour != blank %}
        color: {{ block.settings.font_colour }};
      {% endif %}
      flex-direction: {{ block.settings.text_icon_alignment }};
      {% if block.settings.text_icon_alignment == 'row' %}
        align-items: flex-start;
        text-align: left;
      {% endif %}
    }
    #section-id-{{ section.id }} .review-block--{{ forloop.index }} .review-card__stars {
      color: {{ block.settings.star_colour }};
    }
    #section-id-{{ section.id }} .review-block--{{ forloop.index }} .review-card__text p,
    #section-id-{{ section.id }} .review-block--{{ forloop.index }} .review-card__author {
      font-size: {{ block.settings.font_size }}px;
    }
    #section-id-{{ section.id }} .review-block--{{ forloop.index }} .review-card__image {
      width: {{ block.settings.image_width }}%;
      max-width: 100%;
      height: 100%;
    }
    #section-id-{{ section.id }} .review-block--{{ forloop.index }} .review-body {
      width: calc(100% - {{ block.settings.image_width }}%);
    }
  {%- endfor -%}

  /* ── Nav buttons ── */
  #section-id-{{ section.id }} .slider-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 20px;
  }

  #section-id-{{ section.id }} .slider-nav p{
    font-size: 12px;
    text-align: center;
  }

  /* Hide nav when no carousel needed at that breakpoint */
  {% unless carousel_desk %}
    @media (min-width: 1024px) {
      #section-id-{{ section.id }} .slider-nav { display: none; }
    }
  {% endunless %}
  {% unless carousel_tab %}
    @media (min-width: 768px) and (max-width: 1023px) {
      #section-id-{{ section.id }} .slider-nav { display: none; }
    }
  {% endunless %}
  {% unless carousel_mob %}
    @media (max-width: 767px) {
      #section-id-{{ section.id }} .slider-nav { display: none; }
    }
  {% endunless %}

  #section-id-{{ section.id }} .slider-nav__btn {
    cursor: pointer;
    font-size: 32px;
    line-height: 1;
    padding: 0 12px;
    background: none;
    border: none;
    color: inherit;
    user-select: none;
  }

  #section-id-{{ section.id }} .slider-nav__btn:disabled {
    opacity: 0.2;
    cursor: default;
  }
{%- endstyle -%}

{%- liquid
  assign cols_desk  = section.settings.per_row_desk
  assign cols_tab   = section.settings.per_row_tab
  assign cols_mob   = section.settings.per_row_mobile
  assign item_count = section.blocks.size

  assign last_slide_desk = item_count | minus: cols_desk | plus: 1
  if last_slide_desk < 1
    assign last_slide_desk = 1
  endif

  assign last_slide_tab = item_count | minus: cols_tab | plus: 1
  if last_slide_tab < 1
    assign last_slide_tab = 1
  endif

  assign last_slide_mob = item_count | minus: cols_mob | plus: 1
  if last_slide_mob < 1
    assign last_slide_mob = 1
  endif

  assign carousel_desk = false
  if item_count > cols_desk
    assign carousel_desk = true
  endif

  assign carousel_tab = false
  if item_count > cols_tab
    assign carousel_tab = true
  endif

  assign carousel_mob = false
  if item_count > cols_mob
    assign carousel_mob = true
  endif

  assign any_carousel = false
  if carousel_desk or carousel_tab or carousel_mob
    assign any_carousel = true
  endif
-%}

<div id="section-id-{{ section.id }}" class="section-id-{{ section.id }} collection-slider-row">

  {%- if carousel_desk -%}
    {%- for i in (1..last_slide_desk) -%}
      <input
        type="radio"
        name="slider-desk-{{ section.id }}"
        id="slide-desk-{{ section.id }}-{{ forloop.index }}"
        class="slider-radio"
        style="display:none"
        {% if forloop.first %}checked{% endif %}>
    {%- endfor -%}
  {%- endif -%}

  {%- if carousel_tab -%}
    {%- for i in (1..last_slide_tab) -%}
      <input
        type="radio"
        name="slider-tab-{{ section.id }}"
        id="slide-tab-{{ section.id }}-{{ forloop.index }}"
        class="slider-radio"
        style="display:none"
        {% if forloop.first %}checked{% endif %}>
    {%- endfor -%}
  {%- endif -%}

  {%- if carousel_mob -%}
    {%- for i in (1..last_slide_mob) -%}
      <input
        type="radio"
        name="slider-mob-{{ section.id }}"
        id="slide-mob-{{ section.id }}-{{ forloop.index }}"
        class="slider-radio"
        style="display:none"
        {% if forloop.first %}checked{% endif %}>
    {%- endfor -%}
  {%- endif -%}

  <div>

    {%- if section.settings.title != blank -%}
      <div class="hometitle{% unless section.settings.show_title %} visually-hidden{% endunless %}">
        <h2>{{ section.settings.title | escape }}</h2>
      </div>
    {%- endif -%}

    <div class="product-grid{% if any_carousel %} product-grid--carousel{% endif %}">
      {%- for block in section.blocks -%}
        {%- liquid
          assign filled_stars = block.settings.star_rating
          assign empty_stars  = 5 | minus: filled_stars
        -%}
        <div
          class="review-block--{{ forloop.index }}{% if any_carousel %} slider__item slider__item--{{ forloop.index }}{% endif %}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.link != blank -%}
            <a class="review-card" href="{{ block.settings.link }}" style="text-decoration:none;">
          {%- else -%}
            <div class="review-card">
          {%- endif -%}

            {%- if block.settings.image != blank -%}
              <div class="review-card__image">
                {%- liquid
                  assign image_w      = block.settings.image_width
                  assign image_sizes  = image_w | append: 'px'
                  assign image_widths = image_w | times: 2 | prepend: ', ' | prepend: image_w
                  render 'image' with block.settings.image, sizes: image_sizes, widths: image_widths
                -%}
              </div>
            {%- endif -%}

            <div class="review-body">
              {%- if block.settings.text != blank -%}
                <div class="review-card__text">{{ block.settings.text }}</div>
              {%- endif -%}

              <div>
                {%- if block.settings.author != blank -%}
                  <p class="review-card__author">{{ block.settings.author }}</p>
                {%- endif -%}
                {%- if block.settings.star_rating > 0 -%}
                  <div class="review-card__stars" aria-label="{{ block.settings.star_rating }} out of 5 stars">
                    {%- for i in (1..filled_stars) -%}★{%- endfor -%}
                    {%- if empty_stars > 0 -%}
                      {%- for i in (1..empty_stars) -%}☆{%- endfor -%}
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
            </div>

          {%- if block.settings.link != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if any_carousel -%}
      <div class="slider-nav">
        <button
          class="slider-nav__btn slider-nav__btn--prev"
          data-slider="{{ section.id }}"
          aria-label="Previous"
          disabled
        >&#8249;</button>
        <p>swipe for more reviews</p>
        <button
          class="slider-nav__btn slider-nav__btn--next"
          data-slider="{{ section.id }}"
          aria-label="Next"
        >&#8250;</button>
      </div>
    {%- endif -%}

  </div>
</div>

{%- if any_carousel -%}
<script>
(function () {
  var sectionId     = {{ section.id | json }};
  var lastSlideDesk = {{ last_slide_desk }};
  var lastSlideTab  = {{ last_slide_tab }};
  var lastSlideMob  = {{ last_slide_mob }};
  var carouselDesk  = {{ carousel_desk }};
  var carouselTab   = {{ carousel_tab }};
  var carouselMob   = {{ carousel_mob }};
  var current       = 1;

  var root    = document.getElementById('section-id-' + sectionId);
  var prevBtn = root.querySelector('.slider-nav__btn--prev');
  var nextBtn = root.querySelector('.slider-nav__btn--next');

  function getBreakpoint() {
    var w = window.innerWidth;
    if (w >= 1024) return 'desk';
    if (w >= 768)  return 'tab';
    return 'mob';
  }

  function isCarouselActive() {
    var bp = getBreakpoint();
    if (bp === 'desk') return carouselDesk;
    if (bp === 'tab')  return carouselTab;
    return carouselMob;
  }

  function getLastSlide() {
    var bp = getBreakpoint();
    if (bp === 'desk') return lastSlideDesk;
    if (bp === 'tab')  return lastSlideTab;
    return lastSlideMob;
  }

  function updateNav() {
    var nav = root.querySelector('.slider-nav');
    if (!nav) return;
    nav.style.display = isCarouselActive() ? '' : 'none';
  }

  function goTo(index) {
    if (!isCarouselActive()) return;
    var lastSlide = getLastSlide();
    if (index < 1 || index > lastSlide) return;
    var bp    = getBreakpoint();
    var radio = document.getElementById('slide-' + bp + '-' + sectionId + '-' + index);
    if (radio) radio.checked = true;
    current = index;
    prevBtn.disabled = current === 1;
    nextBtn.disabled = current === lastSlide;
  }

  var resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function () {
      updateNav();
      goTo(1);
    }, 150);
  });

  prevBtn.addEventListener('click', function () { goTo(current - 1); });
  nextBtn.addEventListener('click', function () { goTo(current + 1); });

  updateNav();
  goTo(1);
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "HID Carousel",
  "class": "section-carousel hid-container",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show heading",
      "info": "If not visible, heading is still used for accessibility & SEO",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "range",
      "id": "per_row_desk",
      "label": "Items per row (desktop)",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "per_row_tab",
      "label": "Items per row (tablet)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "per_row_mobile",
      "label": "Items per row (mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Reviewer image"
        },
        {
          "type": "range",
          "id": "image_width",
          "label": "Image width",
          "min": 10,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 50
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Review text"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name"
        },
        {
          "type": "range",
          "id": "star_rating",
          "label": "Star rating",
          "min": 0,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "color",
          "id": "star_colour",
          "label": "Star Colour"
        },
        {
          "type": "radio",
          "id": "text_icon_alignment",
          "label": "Layout",
          "default": "column",
          "options": [
            { "value": "column", "label": "Stacked" },
            { "value": "row",    "label": "Inline"  }
          ]
        },
        {
          "type": "range",
          "id": "font_size",
          "label": "Text size",
          "min": 8,
          "max": 30,
          "step": 1,
          "unit": "px",
          "default": 12
        },
        {
          "type": "color",
          "id": "logo_bg_color",
          "label": "Card background colour"
        },
        {
          "type": "color",
          "id": "font_colour",
          "label": "Text colour"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HID Carousel",
      "category": "HID Landing Page"
    }
  ]
}
{% endschema %}
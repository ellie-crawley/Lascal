{% if product.metafields.custom.accessories_products.value != blank %}
  {{ 'section-accessories.css' | asset_url | stylesheet_tag }}

  <section class="accessories container">
    <div class="accessories__title">{{ section.settings.title }}</div>
    <div class="accessories__wrapper">
      {% for productAcc in product.metafields.custom.accessories_products.value limit: 3 %}
        {% render 'product-card', product: productAcc %}
      {% endfor %}
    </div>
  </section>

  {{ 'product-card.js' | asset_url | script_tag }}
{% endif %}

{% style %}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screeen and (max-width: 760px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | divided_by: 2 }}px;
      padding-bottom: {{ section.settings.padding_bottom | divided_by: 2 }}px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Accessories section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "label": "Padding bottom",
      "default": 80
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "default": "<p>The essential {{ product.title }} <br>accessories</p>"
    }
  ],
  "presets": [
    {
      "category": "Accessories section",
      "name": "Accessories section"
    }
  ]
}
{% endschema %}

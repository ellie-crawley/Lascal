{{ 'section-latest-articles.css' | asset_url | stylesheet_tag }}

<div class="latest-articles__container container">
  <h2 class="recommended-articles__title h2">{{ section.settings.title }}</h2>
  <div class="latest-articles__articles hide-scroll-bar">
    {% assign isCurrentArticle = false %}
    {% for recommended_article in blog.articles limit: 4 %}
      {% if recommended_article == article %}
        {% assign isCurrentArticle = true %}
        {% continue %}
      {% endif %}

      {% render 'article-card', article: recommended_article, classes: 'latest-articles__article' %}

      {% if forloop.index == 3 and isCurrentArticle == false %}
        {% break %}
      {% endif %}
    {% endfor %}
  </div>
</div>

{% style %}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screeen and (max-width: 760px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | divided_by: 2 }}px;
      padding-bottom: {{ section.settings.padding_bottom | divided_by: 2 }}px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Recomended Articles",
  "tag": "section",
  "class": "latest-articles",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "label": "Padding bottom",
      "default": 80
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "You may also like"
    }
  ],
  "presets": [
    {
      "name": "Recomended Articles",
      "category": "Recomended Articles"
    }
  ]
}
{% endschema %}

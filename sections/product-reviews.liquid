{% style %}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.5 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 }}px;
    margin-top: {{ section.settings.margin_top | times: 0.5 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.5 }}px;
    background-color: {{ section.settings.bg_color }}
  }

  @media screen and (min-width:750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }
{% endstyle %}

<div class="product-reviews container">
<div id="reviews"></div>
  {% if section.settings.title != blank %}
    <h2 class="product-reviews__title h2">{{ section.settings.title | replace: '®', '<span class="large_trademark">®</span>' }}</h2>
  {% endif %}
</div>

{% schema %}
{
  "name": "Title",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Product reviews"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Margin top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Margin bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Title"
    }
  ]
}
{% endschema %}

{% if product.metafields.custom.reason_to_choose_1.value != blank %}
  {{ 'section-pdp-benefits-slider.css' | asset_url | stylesheet_tag }}

  <div class="pdp_benefits-slider__container container">
    <h2 class="pdp_benefits-slider__title h2">{{ section.settings.title }}</h2>
    <div class="pdp_benefits-slider__sliders-container">
      <div class="pdp_benefits-slider__main-slider">
        <div class="swiper-wrapper">
          {% for benefit in product.metafields.custom.reason_to_choose_1.value %}
            <div class="swiper-slide pdp_benefits-slider__main-slide">
              <div class="pdp_benefits-slider__main-image image-wrapper">
                {% if benefit.image != blank %}
                  {% render 'image', image: benefit.image %}
                {% else %}
                  {{ 'image' | placeholder_svg_tag }}
                {% endif %}
              </div>
              <div class="pdp_benefits-slider__main-content-wrapper">
                <div class="pdp_benefits-slider__main-content">
                  <h3 class="pdp_benefits-slider__main-title h3">{{ benefit.title | default: 'title' }}</h3>
                  {% if benefit.text != blank %}
                    <div class="pdp_benefits-slider__main-text paragraph">
                      {{ benefit.text | metafield_tag }}
                    </div>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
      <div class="pdp_benefits-slider__thumbs-slider">
        <div class="swiper-wrapper">
          {% for benefit in product.metafields.custom.reason_to_choose_1.value %}
            <div class="pdp_benefits-slider__thumbs-slide swiper-slide">
              <p class="pdp_benefits-slider__thumbs-title">{{ benefit.title | default: 'title' }}</p>
            </div>
          {% endfor %}
        </div>

        <div class="pdp_benefits-slider__button-prev">{% render 'icons', icon: 'arrow-right' %}</div>
        <div class="pdp_benefits-slider__button-next">{% render 'icons', icon: 'arrow-right' %}</div>
      </div>
    </div>
  </div>
{% endif %}

{% style %}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screeen and (max-width: 760px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | divided_by: 2 }}px;
      padding-bottom: {{ section.settings.padding_bottom | divided_by: 2 }}px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Product benefits slider",
  "tag": "section",
  "class": "pdp_benefits-slider",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "label": "Padding bottom",
      "default": 80
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "9 Reason to choose the BuggyBoard® Maxi"
    }
  ],
  "presets": [
    {
      "name": "Product benefits slider",
      "category": "Carousel"
    }
  ]
}
{% endschema %}

{{ 'section-main-article.css' | asset_url | stylesheet_tag }}

<div class="container">
  <div class="article__container">
    <p class="article__date">{{ article.published_at | date: '%d %B %Y' }}</p>
    <h1 class="article__title h2">{{ article.title }}</h1>
    <div class="article__content">
      {{ article.content }}
    </div>
  </div>
</div>

{% style %}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screeen and (max-width: 760px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | divided_by: 2 }}px;
      padding-bottom: {{ section.settings.padding_bottom | divided_by: 2 }}px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Main Article",
  "tag": "section",
  "class": "article",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "label": "Padding bottom",
      "default": 80
    }
  ]
}
{% endschema %}

{% style %}
.hid-product__card {
  border: 1px solid #d5d5d5;
  transition: 0.3s ease;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 10px;
  padding: 20px;
  border-radius: 14px;
}

/* IMAGE */
.hid-product__card-image.image::before {
  padding: 0!important;
}

.hid-product__card-image img {
  display: block;
  transition: 0.3s ease;
  opacity: 1;
  visibility: visible;
  object-fit: contain;
  position: static;
}

/* Hide all images except first */
.hid-product__card-image img:not(:first-child) {
  display: none;
}

/* Hover swap */
.hid-product__card:hover .hid-product__card-image img:first-child {
  opacity: 0;
  visibility: hidden;
}

.hid-product__card:hover .hid-product__card-image img:nth-child(2) {
  display: block;
  opacity: 1;
  visibility: visible;
}

/* JS states (kept for safety) */
.hid-product__card-image img.active.first_show {
  display: block;
  opacity: 1;
  visibility: visible;
}

.hid-product__card-image img.active.hover_show {
  display: none;
}

.hid-product__card:hover .hid-product__card-image img.active.first_show {
  opacity: 0;
  visibility: hidden;
}

.hid-product__card:hover .hid-product__card-image img.active.hover_show {
  display: block;
  opacity: 1;
  visibility: visible;
}

/* TITLE + PRICES */
.hid-product__card-price-title {
  display: flex;
  justify-content: center;
  font-family: "Museo Sans Rounded";
  font-size: 18px;
  font-weight: 400;
  line-height: 22px;
  color: #000;
}

.hid-product__card-title {
  font-size: 18px;
  color: #15110e;
  font-weight: bold;

  sup{
    vertical-align: super;
  }
}

.hid-product__card-prices {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  flex-direction: row;
}

.hid-product__card-price,
.hid-product__card-compare {
  font-size: 16px;
  white-space: nowrap;
}

.hid-product__card-compare {
  text-decoration: line-through;
  opacity: 0.6;
}

/* REVIEW */
.hid-product__card-rating {
  display: flex;
  justify-content: center;
}

.hid-product__card-rating .stamped-product-reviews-badge {
  padding: 3px 5px;
}

.hid-product__card .stamped-badge-caption {
  display: none;
}

/* STAR COLOR */
.hid-product__card .stamped-fa-star:before {
  font-size: 10px;
}
.hid-product__card .stamped-fa-star {
  color: {{btn_star_colour}};
}
.hid-product__card .stamped-starrating{
  display: flex;
  align-items: center;
  gap: 3px;
}

/* BUTTON */
.hid-product__card .form__button {
  margin-top: 10px;
  background: {{btn_colour}};
  color: {{btn_text_colour}};
  border: none;
  width: 100%;
  padding: 11px;
  border-radius: 9px;
  font-weight: 700;
  font-size: 14px;
  text-transform: uppercase;
}

/* LAYOUT */
.hid-product__card-content {
  display: flex;
  flex-direction: column;
  height: 100%;
  justify-content: space-between;
}
{% endstyle %}

<div class="hid-product__card" data-product-url="{{ product.url | split: "?" | first }}">
  <a href="{{ product.url }}" class="hid-product__card-image image">
    {% if configured_image_primary != blank or configured_image_secondary != blank %}
      {% if configured_image_primary != blank %}
        {% render 'image', image: configured_image_primary %}
      {% endif %}
      {% if configured_image_secondary != blank %}
        {% render 'image', image: configured_image_secondary %}
      {% endif %}
    {% else %}
      {% for image in product.images %}
        {% unless image.alt contains '<iframe' %}
          {% render 'image', image: image %}
        {% endunless %}
      {% endfor %}
    {% endif %}
  </a>

  <div class="hid-product__card-content">
    <a href="{{ product.url }}" class="hid-product__card-price-title">
      <div class="hid-product__card-title">
        {% if product_custom_title != blank %}
          {{ product_custom_title }}
        {% else %}
          {{ product.title }}
        {% endif %}
      </div>
    </a>

    <div class="hid-product__card-prices">
      <div class="hid-product__card-price">{{ product.price | money }}</div>
      {% if product.price < product.compare_at_price %}
        <div class="hid-product__card-compare">{{ product.compare_at_price | money }}</div>
      {% endif %}
    </div>

    <a href="{{ product.url }}#reviews" class="hid-product__card-rating">
      <span
        class="stamped-product-reviews-badge product__reviews-badge"
        data-id="{{ product.id }}"
        data-product-sku="{{ product.handle }}"
        data-product-type="{{ product.type }}"
        data-product-title="{{ product.title }}"
        style="display:flex;"
      >
        {% if product.metafields.reviews.rating.value != blank -%}
          ({{ product.metafields.reviews.rating.value }})
        {%- endif %}
      </span>
    </a>

    {% form 'product', product, class: 'main-form', data-cart-submit: 'data-cart-submit' %}
      <input type="hidden" name="form_type" value="product">
      <input type="hidden" name="utf8" value="✓">

      <select name="id" class="product__select" style="display: none;">
        {% for variant in product.variants %}
          <option
            class="select-option"
            data-price="{{ variant.price | money }}"
            {% if variant.compare_at_price > variant.price %}
              data-compare-price="{{ variant.compare_at_price | money }}"
            {% endif %}
            {% unless variant.available %}disabled{% endunless %}
            data-title="{{ variant.title }}"
            value="{{ variant.id }}"
          >
            {{ variant.title }}
          </option>
        {% endfor %}
      </select>

      <button class="form__button" type="submit" name="add"
        {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}>
        {% if product.selected_or_first_available_variant.available %}
          {{ 'products.product.add_to_cart' | t }}
        {% else %}
          {{ 'products.product.sold_out' | t }}
        {% endif %}
      </button>
    {% endform %}
  </div>
</div>
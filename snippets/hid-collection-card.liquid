{%  style %}
.hid-product__card {
  border: 1px solid transparent;
  transition: 0.3s ease;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 10px;
}

.hid-product__card-color {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  margin-right: 6px;
  position: relative;
  cursor: pointer;
}
@media screen and (max-width: 990px) {
  .hid-product__card-color {
    width: 15px;
    height: 15px;
  }
}
.hid-product__card-color.active::before {
  content: "";
  border: 3px solid #d5d5d5;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  position: absolute;
  top: 0;
  left: 0;
}

.hid-product__card-image-container {
  position: relative;
}

.hid-product__card-image {
  display: block;
}
.hid-product__card-image.image::before {
  padding-top: 100%;
}

.hid-product__card-image img {
  display: block;
  transition: 0.3s ease;
  opacity: 1;
  visibility: visible;
}

/* Hide all images except the first by default */
.hid-product__card-image img:not(:first-child) {
  display: none;
}

/* Hover: fade out first, show second */
.hid-product__card:hover .hid-product__card-image img:first-child {
  opacity: 0;
  visibility: hidden;
}
.hid-product__card:hover .hid-product__card-image img:nth-child(2) {
  display: block;
  opacity: 1;
  visibility: visible;
}

/* JS-controlled classes for if JS adds them */
.hid-product__card-image img.active.first_show {
  display: block;
  opacity: 1;
  visibility: visible;
}
.hid-product__card-image img.active.hover_show {
  display: none;
}
.hid-product__card:hover .hid-product__card-image img.active.first_show {
  opacity: 0;
  visibility: hidden;
}
.hid-product__card:hover .hid-product__card-image img.active.hover_show {
  display: block;
  opacity: 1;
  visibility: visible;
}

.hid-product__card-price-title {
  display: flex;
  justify-content: space-between;
  font-family: "Museo Sans Rounded";
  font-size: 18px;
  font-weight: 400;
  line-height: 22px;
  letter-spacing: 0em;
  color: #000000;
}

.hid-product__card-title {
  font-size: 14px;
  color: #15110e;
  font-weight: bold;
}

.hid-product__card-short {
  margin-top: 22px;
  color: var(--Main-Colors-Black, #000);
  font-family: "Open Sans";
  font-size: 16px;
  font-weight: 400;
  line-height: 160%;
}
@media screen and (max-width: 990px) {
  .hid-product__card-short {
    font-size: 14px;
    margin-top: 16px;
  }
}

.hid-product__card-price,
.hid-product__card-compare {
  white-space: nowrap;
  font-size: 18px;
  font-weight: 800;
}

.hid-product__card-prices {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-direction: row;
}
@media (max-width: 767px) {
  .hid-product__card-prices {
    font-size: 14px;
  }
}

.hid-product__card-compare {
  text-decoration: line-through;
  opacity: 0.6;
  white-space: nowrap;
}

.hid-product__card-rating {

}
.hid-product__card-rating .stamped-product-reviews-badge {
  padding: 3px 5px;
}
.hid-product__card-rating .disabled {
  display: none !important;
}

.hid-product__card .stamped-badge-caption {
  display: none;
}

.hid-product__card-add-cart {
  position: relative;
  margin-top: 20px;
  width: 100%;
  display: flex;
  justify-content: center;
  gap: 8px;
  align-items: center;
}
.hid-product__card-add-cart.disabled::after {
  content: "";
  display: block;
  position: absolute;
  top: 50%;
  left: 41%;
  width: 1px;
  height: 33px;
  border-left: 1px solid #000;
  transform: translate(-50%, -50%) rotate(45deg);
}
.hid-product__card-add-cart.disabled::before {
  content: "";
  display: block;
  position: absolute;
  top: 50%;
  left: 41%;
  width: 1px;
  height: 33px;
  border-left: 1px solid #000;
  transform: translate(-50%, -50%) rotate(-45deg);
}

.hid-product__card-add-cart__container {
  border: 1px solid transparent;
}
.hid-product__card-add-cart__container .find-retailer,
.hid-product__card-add-cart__container .hid-product__card-add-cart {
  transition: 0.3s all ease;
}
.hid-product__card-add-cart__container svg path {
  transition: 0.3s all ease;
}

.hid-product__card:hover .hid-product__card-add-cart__container .find-retailer,
.hid-product__card:hover .hid-product__card-add-cart__container .hid-product__card-add-cart:not(.icon) {
  background: #ff8300;
  color: #fff;
  border-color: #ff8300;
}
.hid-product__card:hover .hid-product__card-add-cart__container .find-retailer svg path,
.hid-product__card:hover .hid-product__card-add-cart__container .hid-product__card-add-cart:not(.icon) svg path {
  stroke: #fff;
}

.hid-product__card-add-cart.loading {
  pointer-events: none;
}

.hid-product__card-add-cart .loading-state {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  opacity: 0;
  visibility: hidden;
  transition: 0.2s ease;
  z-index: 2;
}

.hid-product__card-add-cart.loading .loading-state {
  opacity: 1;
  visibility: visible;
}

.lds-dual-ring {
  display: inline-block;
  width: 35px;
  height: 35px;
}

.lds-dual-ring:after {
  content: " ";
  display: block;
  width: 30px;
  height: 30px;
  margin: 4px;
  border-radius: 50%;
  border: 2px solid #fff;
  border-color: #000 transparent #000 transparent;
  animation: lds-dual-ring 1.2s linear infinite;
}

.hid-product__card-add-cart__container .find-retailer {
  display: block;
  margin-top: 20px;
  text-align: center;
}

@keyframes lds-dual-ring {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}
.hid-product__card-variants {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: -6px;
}

.hid-product__card-variants-item {
  border-radius: 50%;
  border: 1px solid #C7C7CC;
  max-width: 35px;
  max-height: 35px;
}
.hid-product__card-variants-item.active {
  border: 1px solid #FF8300;
}
.hid-product__card-variants-item img {
  border-radius: 50%;
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.hid-product__card-rating,
.hid-product__card-prices,
.hid-product__card-price-title{
  display: flex;
  justify-content: center;
}

.stamped-fa-star{
  color: #FF8300;
}
.stamped-fa-star:before,
.stamped-fa-star{
  font-size: 11px
}

.form__button {
  margin-top: 10px;
  background: #FF8300;
  color: #fff;
  border: none;
  width: 100%;
  padding: 11px;
  border-radius: 9px;
  font-weight: 700;
  font-size: 13px;
}
.hid-product__card-content {
  display: flex;
  flex-direction: column;
  height: 100%;
  justify-content: space-between;
}
{% endstyle %}

<div class="hid-product__card" data-product-url="{{ product.url |  split: "?" | first }}">
  <a href="{{ product.url }}" class="hid-product__card-image image">
    {% if configured_image_primary != blank or configured_image_secondary != blank %}
      {% if configured_image_primary != blank %}
        {% render 'image', image: configured_image_primary %}
      {% endif %}
      {% if configured_image_secondary != blank %}
        {% render 'image', image: configured_image_secondary %}
      {% endif %}
    {% else %}
      {% for image in product.images %}
        {% unless image.alt contains '<iframe' %}
          {% render 'image', image: image %}
        {% endunless %}
      {% endfor %}
    {% endif %}
  </a>

  <div class="hid-product__card-content">
    <a href="{{ product.url }}" class="hid-product__card-price-title">
      <div class="hid-product__card-title">{{ product.title }}</div>
    </a>
    <div class="hid-product__card-prices">
      <div class="hid-product__card-price">{{ product.price | money }}</div>
      {% if product.price < product.compare_at_price %}
        <div class="hid-product__card-compare">{{ product.compare_at_price | money }}</div>
      {% endif %}
    </div>
    <a href="{{ product.url }}#reviews" class="hid-product__card-rating">
      <span
        class="stamped-product-reviews-badge product__reviews-badge"
        data-id="{{ product.id }}"
        data-product-sku="{{ product.handle }}"
        data-product-type="{{product.type}}"
        data-product-title="{{product.title}}"
        style="display:flex;"
      >
      </span>
    </a>
    {% form 'product', product, class: 'main-form', data-cart-submit: 'data-cart-submit' %}
      <input type="hidden" name="form_type" value="product">
      <input type="hidden" name="utf8" value="✓">
      <select name="id" class="product__select" style="display: none;">
        {% for variant in product.variants %}
          <option
            class="select-option"
            data-price="{{ variant.price | money }}"
            {% if variant.compare_at_price > variant.price %}
              data-compare-price="{{ variant.compare_at_price | money }}"
            {% endif %}
            {% unless variant.available %}
              disabled
            {% endunless %}
            data-title="{{variant.title}}"
            value="{{variant.id}}"
          >
            {{ variant.title }}
          </option>
        {% endfor %}
      </select>
      <button class="form__button" type="submit" name="add" {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}>
        {%- if product.selected_or_first_available_variant.available -%}
        {{ 'products.product.add_to_cart' | t }}
        {%- else -%}
        {{ 'products.product.sold_out' | t }}
        {%- endif -%}
      </button>
    {% endform %}
  </div>
</div>
